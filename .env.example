# ---- HTTP -------------------------------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
# Port published on the host machine for the app
HTTP_PUBLISHED_PORT=8000

# ---- Postgres (in-container) ------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=baseledger
POSTGRES_USER=baseledger
POSTGRES_PASSWORD=password
# Port published on the host machine for postgres
POSTGRES_PUBLISHED_PORT=5432

# ---- Pekko ------------------------------------------------------------------
PEKKO_REMOTE_HOSTNAME=127.0.0.1
PEKKO_REMOTE_PORT=2551
# Options: OFF, ERROR, WARNING, INFO, DEBUG
PEKKO_LOGLEVEL=INFO
PEKKO_NUMBER_OF_SHARDS=100

# ---- DB connection pool (Slick) ---------------------------------------------
DB_NUM_THREADS=10
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1

# ---- OpenTelemetry ----------------------------------------------------------
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=baseledger

# ---- Observability ports (published on the host) ----------------------------
GRAFANA_PUBLISHED_PORT=3000
OTEL_GRPC_PUBLISHED_PORT=4317

# ---- HTTP Server Performance / Throughput Tuning -----------------------------
HTTP_SERVER_BACKLOG=8192
HTTP_SERVER_MAX_CONNECTIONS=16384
HTTP_SERVER_HTTP2_MAX_CONCURRENT_STREAMS=1024
HTTP_SERVER_PIPELINING_LIMIT=16
HTTP_SERVER_ENABLE_HTTP2=on
HTTP_SERVER_USE_DISPATCHER=http-dispatcher

# ---- HTTP Server Dispatcher Tuning -------------------------------------------
HTTP_DISPATCHER_PARALLELISM_MIN=8
HTTP_DISPATCHER_PARALLELISM_FACTOR=3.0
HTTP_DISPATCHER_PARALLELISM_MAX=64
HTTP_DISPATCHER_THROUGHPUT=100

# ---- Shared R2DBC Connection Pool Tuning -------------------------------------
R2DBC_POOL_MAX_SIZE=100
R2DBC_POOL_INITIAL_SIZE=20

# ---- Pekko Default Dispatcher Tuning ----------------------------------------
PEKKO_DEFAULT_DISPATCHER_PARALLELISM_FACTOR=3.0
PEKKO_DEFAULT_DISPATCHER_PARALLELISM_MAX=64
PEKKO_DEFAULT_DISPATCHER_THROUGHPUT=100

# ---- Container images -------------------------------------------------------
POSTGRES_IMAGE=postgres:18-alpine
FLYWAY_IMAGE=flyway/flyway:12-alpine
OTEL_LGTM_IMAGE=grafana/otel-lgtm:0.11.10
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.110.0
APP_IMAGE=ghcr.io/baseledger-io/baseledger:latest
